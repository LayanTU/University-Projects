{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe build active file",
            "command": "C:/msys64/ucrt64/bin/g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-std=c++17",
                "${workspaceFolder}/src/*.cpp",
                "-I${workspaceFolder}/include",
                "-L${workspaceFolder}/lib",
                "-lfreeglut",
                "-lglu32",
                "-lopengl32",
                "-lgdi32",
                "-o", 
                "${workspaceFolder}/Classroom-OpenGL.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated for FreeGLUT"
        }
    ]
}